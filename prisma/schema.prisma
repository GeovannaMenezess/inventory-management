generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id             String   @id @default(uuid())
  name           String
  description    String?
  price          Decimal
  stock_quantity Int      @default(0)
  created_at     DateTime @default(now())
}